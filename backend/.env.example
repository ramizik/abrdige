# Copy to .env
# Anthropic key for the live extraction path. Optional — demo mode works without it.
ANTHROPIC_API_KEY=

# 1 = always use precomputed deterministic deltas (demo-safe default)
# 0 = try live Agent SDK extraction, fall back to deterministic on failure
BRIDGE_DEMO_MODE=1

# Model for the mid-visit Analyze pipeline (POST /visits/{id}/analyze).
# claude-sonnet-5 = best extraction quality (~30-80s); claude-haiku-4-5-20251001 = faster.
BRIDGE_ANALYSIS_MODEL=claude-sonnet-5
