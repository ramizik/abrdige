{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "services": {
        "frontend": {
            "root": "frontend/",
            "framework": "vite"
        },
        "backend": {
            "root": "backend/",
            "framework": "fastapi",
            "entrypoint": "app.main:app",
            "routes": [
                {
                    "src": "/api/(.*)",
                    "transforms": [
                        {
                            "type": "request.path",
                            "op": "set",
                            "args": "/$1"
                        }
                    ]
                }
            ]
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": {
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "service": "frontend"
            }
        }
    ]
}
